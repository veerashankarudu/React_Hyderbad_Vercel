#!/bin/sh
# QuizHub Hook: pre-commit
# Runs automatically every time you do: git commit
# Checks code quality BEFORE the commit is saved
set -o pipefail

echo "🔍 QuizHub pre-commit checks running..."

# ── 1. Compile check (fast — no test execution) ──────────────────
echo "  ▸ Checking backend compiles..."
cd backend && mvn compile test-compile -q 2>&1; BACKEND_EXIT=$?
if [ $BACKEND_EXIT -ne 0 ]; then
  echo "  ❌ Backend compile FAILED. Fix before committing."
  exit 1
fi
echo "  ✅ Backend compiles OK"
cd ..

# ── 2. Check frontend compiles (no build output) ─────────────────
echo "  ▸ Checking frontend for syntax errors..."
cd frontend && npx react-scripts build --silent 2>&1; FRONTEND_EXIT=$?
if [ $FRONTEND_EXIT -ne 0 ]; then
  echo "  ❌ Frontend build FAILED. Fix before committing."
  exit 1
fi
echo "  ✅ Frontend build OK"
cd ..

echo "✅ All pre-commit checks passed. Committing..."
exit 0
