#!/bin/sh
# QuizHub Hook: pre-commit
# Runs automatically every time you do: git commit
# Checks code quality BEFORE the commit is saved

echo "🔍 QuizHub pre-commit checks running..."

# ── 1. Run backend tests ──────────────────────────────────────────
echo "  ▸ Running backend tests..."
cd backend && mvn test -q 2>&1 | tail -5
if [ $? -ne 0 ]; then
  echo "  ❌ Backend tests FAILED. Fix before committing."
  exit 1
fi
echo "  ✅ Backend tests passed"
cd ..

# ── 2. Check frontend builds without errors ───────────────────────
echo "  ▸ Checking frontend build..."
cd frontend && npx react-scripts build --silent 2>&1 | tail -3
if [ $? -ne 0 ]; then
  echo "  ❌ Frontend build FAILED. Fix before committing."
  exit 1
fi
echo "  ✅ Frontend build OK"
cd ..

echo "✅ All pre-commit checks passed. Committing..."
exit 0
