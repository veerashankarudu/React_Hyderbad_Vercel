#!/bin/sh
# QuizHub Hook: commit-msg
# Runs automatically on every commit
# Enforces conventional commit message format

commit_msg=$(cat "$1")

# Must match: type(scope): description
# Examples:
#   feat: add bulk upload
#   fix(auth): handle token expiry
#   test: add MCQ controller tests

pattern="^(feat|fix|docs|test|refactor|chore|style|perf)(\(.+\))?: .{10,}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Invalid commit message format!"
  echo ""
  echo "Required: type(scope): description (min 10 chars)"
  echo ""
  echo "Types: feat | fix | docs | test | refactor | chore | style | perf"
  echo ""
  echo "Examples:"
  echo "  feat: add bulk MCQ upload from CSV"
  echo "  fix(auth): handle expired JWT token"
  echo "  test: add duplicate detection unit tests"
  echo ""
  echo "Your message: $commit_msg"
  echo ""
  exit 1
fi

echo "✅ Commit message format OK"
exit 0
