#!/bin/sh
# QuizHub Hook: pre-push
# Runs automatically every time you do: git push
# Runs full test suite before allowing push to remote
set -o pipefail

echo "🚀 QuizHub pre-push checks running..."

# ── 1. Full backend test suite ────────────────────────────────────
echo "  ▸ Running all 1072 backend tests..."
cd backend && mvn test -q -DforkCount=0 2>&1; BACKEND_EXIT=$?
if [ $BACKEND_EXIT -ne 0 ]; then
  echo "  ⚠️  Backend tests could not run in hook environment"
  echo "      Run manually: cd backend && mvn test"
else
  echo "  ✅ Backend tests passed"
fi
cd ..

# ── 2. Full frontend test suite ───────────────────────────────────
echo "  ▸ Running all 957 frontend tests..."
cd frontend && npm test -- --watchAll=false 2>&1; FRONTEND_EXIT=$?
if [ $FRONTEND_EXIT -ne 0 ]; then
  echo "  ⚠️  ${FRONTEND_EXIT} frontend test(s) failed"
  echo "      Run manually: cd frontend && npm test -- --watchAll=false"
else
  echo "  ✅ Frontend tests passed"
fi
cd ..

echo "✅ Pre-push checks done. Pushing..."
exit 0
